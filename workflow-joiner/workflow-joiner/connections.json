{
  "managedApiConnections": {
    "azureautomation": {
      "api": {
        "id": "/subscriptions/@appsetting('SUBSCRIPTION_ID')/providers/Microsoft.Web/connections/azureautomation"
      },
      "connection": {
        "id": "/subscriptions/@appsetting('SUBSCRIPTION_ID')/resourceGroups/@appsetting('RESOURCE_GROUP_NAME')/providers/Microsoft.Web/connections/@appsetting('AZUREAUTOMATION_CONNECTION_NAME')"
      },
      "authentication": {
        "type": "ManagedServiceIdentity",
        "identity": {
          "userAssignedIdentity": "@appsetting('USER_ASSIGNED_IDENTITY_RESOURCE_ID')"
        }
      },
      "connectionProperties": {
        "authentication": {
          "type": "ManagedServiceIdentity",
          "audience": "https://management.core.windows.net/"
        }
      }
    },
    "keyvault": {
      "api": {
        "id": "/subscriptions/@appsetting('SUBSCRIPTION_ID')/providers/Microsoft.Web/locations/switzerlandnorth/managedApis/keyvault"
      },
      "connection": {
        "id": "/subscriptions/@appsetting('SUBSCRIPTION_ID')/resourceGroups/@appsetting('RESOURCE_GROUP_NAME')/providers/Microsoft.Web/connections/@appsetting('KEYVAULT_CONNECTION_NAME')"
      },
      "authentication": {
        "type": "ManagedServiceIdentity",
        "identity": {
          "userAssignedIdentity": "@appsetting('USER_ASSIGNED_IDENTITY_RESOURCE_ID')"
        }
      },
      "connectionProperties": {
        "authentication": {
          "type": "ManagedServiceIdentity",
          "audience": "https://vault.azure.net"
        }
      }
    },
    "acsemail": {
      "api": {
        "id": "/subscriptions/@appsetting('SUBSCRIPTION_ID')/providers/Microsoft.Web/locations/switzerlandnorth/managedApis/acsemail"
      },
      "connection": {
        "id": "/subscriptions/@appsetting('SUBSCRIPTION_ID')/resourceGroups/@appsetting('RESOURCE_GROUP_NAME')/providers/Microsoft.Web/connections/@appsetting('ACSEMAIL_CONNECTION_NAME')"
      },
      "authentication": {
        "type": "ManagedServiceIdentity",
        "identity": {
          "userAssignedIdentity": "@appsetting('USER_ASSIGNED_IDENTITY_RESOURCE_ID')"
        }
      }
    },
    "azurecommunicationservicessms": {
      "api": {
        "id": "/subscriptions/@appsetting('SUBSCRIPTION_ID')/providers/Microsoft.Web/locations/switzerlandnorth/managedApis/azurecommunicationservicessms"
      },
      "connection": {
        "id": "/subscriptions/@appsetting('SUBSCRIPTION_ID')/resourceGroups/@appsetting('RESOURCE_GROUP_NAME')/providers/Microsoft.Web/connections/@appsetting('AZURECOMMUNICATIONSERVICESSMS_CONNECTION_NAME')"
      },
      "authentication": {
        "type": "ManagedServiceIdentity",
        "identity": {
          "userAssignedIdentity": "@appsetting('USER_ASSIGNED_IDENTITY_RESOURCE_ID')"
        }
      }
    }
  },
  "serviceProviderConnections": {
    "AzureFile": {
      "parameterValues": {
        "connectionString": "@appsetting('AzureFile_connectionString')"
      },
      "parameterSetName": "connectionString",
      "serviceProvider": {
        "id": "/serviceProviders/AzureFile"
      },
      "displayName": "@appsetting('AZUREFILE_CONNECTION_NAME')"
    }
  }
}